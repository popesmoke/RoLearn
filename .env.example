# Database — Neon PostgreSQL (recommended free tier)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# App URL (use your *.vercel.app URL in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Session secret — run: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""

# File storage — pick ONE option:

# Option A: Supabase Storage (recommended — free, NO credit card)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET_NAME="uploads"

# Option B: Cloudflare R2 (requires credit card on Cloudflare account)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="rolearn-uploads"
R2_PUBLIC_URL=""

# Optional: Redis cache (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: transactional email (Resend)
RESEND_API_KEY=""

# Platform owner — full control (comma-separated Roblox usernames)
OWNER_USERNAMES="yourrobloxusername"

# Admin access — management panel (comma-separated Roblox usernames)
ADMIN_USERNAMES=""

# Cron secret for /api/cron/expire-posts (optional)
CRON_SECRET=""
