generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillCategory {
  SCRIPTER
  BUILDER
  UI_DESIGNER
  ANIMATOR
  MODELER
  VFX_ARTIST
  SOUND_DESIGNER
  COMPOSER
  GAME_DESIGNER
  MONETIZATION_SPECIALIST
  COMMUNITY_MANAGER
}

enum TrustLevel {
  NEW
  RISING
  TRUSTED
  VERIFIED
  ELITE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ListingType {
  SERVICE
  JOB
  TEAM
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  username         String?            @unique
  displayName      String?
  avatarUrl        String?
  googleId         String?            @unique
  robloxUserId     String?            @unique
  robloxUsername   String?            @unique
  isVerified       Boolean            @default(false)
  accountAgeDays   Int                @default(0)
  aboutMe          String?
  hireMeOpen       Boolean            @default(false)
  trustScore       Int                @default(0)
  trustLevel       TrustLevel         @default(NEW)
  reputationPoints Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  skills                    UserSkill[]
  portfolioItems            PortfolioItem[]
  coursesCreated            CourseInstructor[]
  serviceOffers             ServiceOffer[]
  jobPosts                  JobPost[]                  @relation("JobPostAuthor")
  teamPosts                 TeamPost[]                 @relation("TeamPostAuthor")
  reviewsReceived           Review[]                   @relation("Reviewee")
  reviewsGiven              Review[]                   @relation("Reviewer")
  applications              Application[]
  conversationParticipation ConversationParticipant[]
  messagesSent              Message[]
}

model VerificationChallenge {
  id             String   @id @default(cuid())
  robloxUsername String
  code           String
  robloxUserId   String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([robloxUsername])
}

model UserSkill {
  id       String        @id @default(cuid())
  userId   String
  category SkillCategory
  level    Int           @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model PortfolioItem {
  id                String   @id @default(cuid())
  userId            String
  title             String
  description       String?
  experienceId      String?
  groupId           String?
  assetId           String?
  ownershipVerified Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  isPaid      Boolean  @default(false)
  priceCents  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instructors CourseInstructor[]
}

model CourseInstructor {
  id              String @id @default(cuid())
  courseId        String
  userId          String
  revenueSharePct Int    @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
}

model ServiceOffer {
  id          String        @id @default(cuid())
  userId      String
  title       String
  category    SkillCategory
  description String
  basePrice   Int?
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobPost {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  description String
  budgetMin   Int?
  budgetMax   Int?
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())

  author User @relation("JobPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model TeamPost {
  id          String        @id @default(cuid())
  authorId    String
  title       String
  description String
  neededRole  SkillCategory
  isOpen      Boolean       @default(true)
  createdAt   DateTime      @default(now())

  author User @relation("TeamPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model Application {
  id          String            @id @default(cuid())
  applicantId String
  listingType ListingType
  listingId   String
  message     String?
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  applicant User @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([applicantId, listingType, listingId])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}
