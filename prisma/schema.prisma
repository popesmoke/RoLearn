generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillCategory {
  SCRIPTER
  BUILDER
  UI_DESIGNER
  ANIMATOR
  MODELER
  VFX_ARTIST
  SOUND_DESIGNER
  COMPOSER
  GAME_DESIGNER
  MONETIZATION_SPECIALIST
  COMMUNITY_MANAGER
}

enum TrustLevel {
  NEW
  RISING
  TRUSTED
  VERIFIED
  ELITE
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  displayName      String?
  avatarUrl        String?
  googleId         String?            @unique
  robloxUserId     String?            @unique
  robloxUsername   String?
  isVerified       Boolean            @default(false)
  accountAgeDays   Int                @default(0)
  aboutMe          String?
  hireMeOpen       Boolean            @default(false)
  trustScore       Int                @default(0)
  trustLevel       TrustLevel         @default(NEW)
  reputationPoints Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  skills           UserSkill[]
  portfolioItems   PortfolioItem[]
  coursesCreated   CourseInstructor[]
  serviceOffers    ServiceOffer[]
  jobPosts         JobPost[]          @relation("JobPostAuthor")
  teamPosts        TeamPost[]         @relation("TeamPostAuthor")
  reviewsReceived  Review[]           @relation("Reviewee")
  reviewsGiven     Review[]           @relation("Reviewer")
}

model UserSkill {
  id       String        @id @default(cuid())
  userId   String
  category SkillCategory
  level    Int           @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model PortfolioItem {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String?
  experienceId    String?
  groupId         String?
  assetId         String?
  ownershipVerified Boolean @default(false)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  isPaid      Boolean  @default(false)
  priceCents  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instructors CourseInstructor[]
}

model CourseInstructor {
  id              String @id @default(cuid())
  courseId        String
  userId          String
  revenueSharePct Int    @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
}

model ServiceOffer {
  id          String   @id @default(cuid())
  userId      String
  title       String
  category    SkillCategory
  description String
  basePrice   Int?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobPost {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  description String
  budgetMin   Int?
  budgetMax   Int?
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())

  author User @relation("JobPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model TeamPost {
  id          String        @id @default(cuid())
  authorId    String
  title       String
  description String
  neededRole  SkillCategory
  isOpen      Boolean       @default(true)
  createdAt   DateTime      @default(now())

  author User @relation("TeamPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}
