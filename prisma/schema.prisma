generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum SkillCategory {
  SCRIPTER
  BUILDER
  UI_DESIGNER
  ANIMATOR
  MODELER
  VFX_ARTIST
  SOUND_DESIGNER
  COMPOSER
  GAME_DESIGNER
  MONETIZATION_SPECIALIST
  COMMUNITY_MANAGER
}

enum TrustLevel {
  NEW
  RISING
  TRUSTED
  VERIFIED
  ELITE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum ListingType {
  SERVICE
  JOB
  TEAM
}

enum PaymentCurrency {
  USD
  ROBUX
  BOTH
}

enum UserRole {
  USER
  MOD
  ADMIN
  OWNER
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  username         String?    @unique
  displayName      String?
  avatarUrl        String?
  googleId         String?    @unique
  robloxUserId     String?    @unique
  robloxUsername   String?    @unique
  isVerified       Boolean    @default(false)
  accountAgeDays   Int        @default(0)
  aboutMe          String?
  hireMeOpen       Boolean    @default(false)
  trustScore       Int        @default(0)
  trustLevel       TrustLevel @default(NEW)
  reputationPoints Int        @default(0)
  role             UserRole   @default(USER)
  responseCount    Int        @default(0)
  responseTotalMin Int        @default(0)
  onboardingDone   Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  skills                    UserSkill[]
  portfolioItems            PortfolioItem[]
  coursesCreated            CourseInstructor[]
  serviceOffers             ServiceOffer[]
  jobPosts                  JobPost[]                 @relation("JobPostAuthor")
  teamPosts                 TeamPost[]                @relation("TeamPostAuthor")
  reviewsReceived           Review[]                  @relation("Reviewee")
  reviewsGiven              Review[]                  @relation("Reviewer")
  applications              Application[]
  conversationParticipation ConversationParticipant[]
  messagesSent              Message[]
  likes                     PostLike[]
  notifications             Notification[]
  bookmarks                 Bookmark[]
  followers                 Follow[]                  @relation("Following")
  following                 Follow[]                  @relation("Follower")
  reportsFiled              Report[]                  @relation("Reporter")
  profileViews              ProfileView[]             @relation("ProfileViewed")
}

model VerificationChallenge {
  id             String   @id @default(cuid())
  robloxUsername String
  code           String
  robloxUserId   String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([robloxUsername])
}

model UserSkill {
  id       String        @id @default(cuid())
  userId   String
  category SkillCategory
  level    Int           @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

enum CourseFormat {
  WRITTEN
  PDF
  MIXED
}

model PortfolioItem {
  id                String   @id @default(cuid())
  userId            String
  title             String
  description       String?
  experienceId      String?
  groupId           String?
  assetId           String?
  mediaUrls         String[] @default([])
  ownershipVerified Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String       @id @default(cuid())
  title       String
  summary     String?
  description String
  format      CourseFormat @default(WRITTEN)
  coverUrl    String?
  pdfUrl      String?
  content     String?
  mediaUrls   String[]     @default([])
  isPaid      Boolean      @default(false)
  priceCents  Int          @default(0)
  isPublished Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  instructors CourseInstructor[]
}

model CourseInstructor {
  id              String @id @default(cuid())
  courseId        String
  userId          String
  revenueSharePct Int    @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Review {
  id            String   @id @default(cuid())
  reviewerId    String
  revieweeId    String
  applicationId String?
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  reviewer    User         @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User         @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@unique([applicationId, reviewerId])
}

model ServiceOffer {
  id          String          @id @default(cuid())
  userId      String
  title       String
  category    SkillCategory
  description String
  basePrice   Int?
  currency    PaymentCurrency @default(USD)
  mediaUrls   String[]        @default([])
  isFeatured  Boolean         @default(false)
  viewCount   Int             @default(0)
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([isFeatured, createdAt(sort: Desc)])
  @@index([category])
}

model JobPost {
  id          String          @id @default(cuid())
  authorId    String
  title       String
  description String
  budgetMin   Int?
  budgetMax   Int?
  currency    PaymentCurrency @default(USD)
  mediaUrls   String[]        @default([])
  isOpen      Boolean         @default(true)
  isFeatured  Boolean         @default(false)
  viewCount   Int             @default(0)
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())

  author User @relation("JobPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([authorId])
  @@index([isOpen, createdAt(sort: Desc)])
  @@index([isFeatured, createdAt(sort: Desc)])
}

model TeamPost {
  id          String        @id @default(cuid())
  authorId    String
  title       String
  description String
  neededRole  SkillCategory
  mediaUrls   String[]      @default([])
  isOpen      Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  viewCount   Int           @default(0)
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())

  author User @relation("TeamPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([authorId])
  @@index([isOpen, createdAt(sort: Desc)])
  @@index([neededRole])
  @@index([isFeatured, createdAt(sort: Desc)])
}

model Application {
  id               String            @id @default(cuid())
  applicantId      String
  listingType      ListingType
  listingId        String
  message          String?
  status           ApplicationStatus @default(PENDING)
  conversationId   String?
  completedAt      DateTime?
  ownerReviewed    Boolean           @default(false)
  applicantReviewed Boolean          @default(false)
  createdAt        DateTime          @default(now())

  applicant User    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  reviews   Review[]

  @@unique([applicantId, listingType, listingId])
  @@index([listingType, listingId])
  @@index([applicantId])
}

model PostLike {
  id          String      @id @default(cuid())
  userId      String
  listingType ListingType
  listingId   String
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingType, listingId])
  @@index([listingType, listingId])
}

model Bookmark {
  id          String      @id @default(cuid())
  userId      String
  listingType ListingType
  listingId   String
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingType, listingId])
  @@index([userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  link        String?
  priority    Int       @default(0)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([publishedAt(sort: Desc)])
}

model PostView {
  id          String      @id @default(cuid())
  listingType ListingType
  listingId   String
  viewerId    String?
  createdAt   DateTime    @default(now())

  @@index([listingType, listingId])
  @@index([createdAt(sort: Desc)])
}

model ProfileView {
  id        String   @id @default(cuid())
  profileId String
  viewerId  String?
  createdAt DateTime @default(now())

  profile User @relation("ProfileViewed", fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([createdAt(sort: Desc)])
}

model Report {
  id          String      @id @default(cuid())
  reporterId  String
  targetType  String
  targetId    String
  reason      String
  details     String?
  resolved    Boolean     @default(false)
  createdAt   DateTime    @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([resolved, createdAt(sort: Desc)])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  mediaUrl       String?
  mediaType      String?
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}
